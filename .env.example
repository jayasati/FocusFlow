DATABASE_URL="file:./dev.db"
AUTH_SECRET=""

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SIGNING_SECRET=

# Neon Postgres
# DATABASE_URL is the pooled connection string used at runtime.
# DIRECT_URL is the unpooled one used by Prisma for migrations / introspection.
DATABASE_URL="postgresql://neondb_owner:xyz/neondb?sslmode=verify-full"
DIRECT_URL="postgresql://neondb_owner:xyz/neondb?sslmode=verify-full"

# Public origin used for OAuth redirect URIs. In dev keep this as
# http://localhost:3000 (no trailing slash). In prod set to your real domain.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# GitHub OAuth App (https://github.com/settings/developers)
# Authorization callback URL must be:
#   ${NEXT_PUBLIC_APP_URL}/api/integrations/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
