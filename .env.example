DATABASE_URL="file:./dev.db"
AUTH_SECRET=""

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Neon Postgres
# DATABASE_URL is the pooled connection string used at runtime.
# DIRECT_URL is the unpooled one used by Prisma for migrations / introspection.
DATABASE_URL="postgresql://neondb_owner:xyz/neondb?sslmode=require"
DIRECT_URL="postgresql://neondb_owner:xyz/neondb?sslmode=require"
